menu "Open Source Components"

config OPEN_SOURCE_LVGL
    bool "Enable LVGL (Light and Versatile Graphics Library)"
    default n
    help
        LVGL v9.4.0 embedded graphics library for building UIs.
        When enabled, sources under open_source/lvgl/ will be compiled.

        If your project does not need a GUI, disable this to reduce
        build time and firmware size.

if OPEN_SOURCE_LVGL
osource "open_source/lvgl/Kconfig"
endif

endmenu
