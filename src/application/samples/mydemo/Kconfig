# src/application/samples/mydemo/Kconfig

config SAMPLE_SUPPORT_HELLOWORLD
    bool
    prompt "Support HELLOWORLD Sample."
    default n
    depends on ENABLE_MYDEMO_SAMPLE
    help
        This option means support HELLOWORLD Sample.

