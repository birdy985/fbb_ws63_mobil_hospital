    help
        This option means support AD8232 ECG ADC Sample.

config SAMPLE_SUPPORT_SPO2_SENSOR
    bool
    prompt "Support MAX30102 SpO2 Sensor Sample."
    default n
    depends on ENABLE_MYDEMO_SAMPLE
    help
        This option means support MAX30102 SpO2 raw PPG debug UART sample.

config SAMPLE_SUPPORT_WIFI
    bool
    prompt "Support WIFI Sample."
    default y
    depends on ENABLE_MYDEMO_SAMPLE
    help
        This option means support WIFI Sample.

config SAMPLE_SUPPORT_SLE
    bool
    prompt "Support SLE Sample."
    default y
    depends on ENABLE_MYDEMO_SAMPLE
    help
        This option means support SLE Sample.

if SAMPLE_SUPPORT_SLE
choice
    prompt "Select mydemo SLE sample"
    default SAMPLE_SUPPORT_SLE_UART
    config SAMPLE_SUPPORT_SLE_UART
        bool "Support SLE UART passthrough sample."
    config SAMPLE_SUPPORT_AD8232_SLE
        bool "Support AD8232 ECG SLE transport sample."
endchoice

if SAMPLE_SUPPORT_SLE_UART
osource "application/samples/mydemo/12_sle/Kconfig"
endif

if SAMPLE_SUPPORT_AD8232_SLE
osource "application/samples/mydemo/13_ad8232_sle/Kconfig"
endif
endif
